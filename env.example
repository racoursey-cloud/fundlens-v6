# FundLens v6 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to GitHub.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# JWT secret for verifying auth tokens (from Supabase → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Claude AI (Anthropic) ────────────────────────────────────────────────────
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Financial Modeling Prep ($19/mo Starter) ─────────────────────────────────
# From financialmodelingprep.com → Dashboard → API Key
FMP_API_KEY=your-fmp-key

# ─── Tiingo (backup — may not be needed if FMP covers mutual fund NAVs) ──────
TINNGO_KEY=your-tiingo-key

# ─── FRED (Federal Reserve Economic Data) ─────────────────────────────────────
# From fred.stlouisfed.org → My Account → API Keys
FRED_API_KEY=your-fred-key

# ─── Resend (email delivery for auth links + Investment Briefs) ───────────────
# From resend.com → API Keys
RESEND_API_KEY=re_your-resend-key

# ─── Server ───────────────────────────────────────────────────────────────────
# Railway sets PORT and NODE_ENV automatically. Only needed for local dev.
PORT=3000
NODE_ENV=development
